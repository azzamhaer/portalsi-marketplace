APP_NAME=MPSI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=portalsi
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# CORS - frontend SvelteKit/dev/production
# Local APP_ENV automatically allows localhost and private LAN origins.
# Use these lists for production domains or other explicit origins.
SANCTUM_STATEFUL_DOMAINS=localhost:5173
SESSION_DOMAIN=localhost
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://marketplace.portalsi.com,https://www.marketplace.portalsi.com
CORS_ALLOWED_ORIGIN_PATTERNS=

# Tripay Payment Gateway
# Daftar gratis di https://tripay.co.id
# Mode: sandbox | production
TRIPAY_MODE=sandbox
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=T0001
